generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  password          String
  role              Role              @default(USER)
  emailVerified     DateTime?
  verificationToken String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  name      String?
  events    BonusMalusEvent[] @relation("AdminEvents")
  team      Team?
}

model Artist {
  id         String            @id @default(uuid())
  name       String
  cost       Int
  image      String?
  type       ArtistType        @default(ARTISTA)
  totalScore Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  events     BonusMalusEvent[]
  teams      Team[]            @relation("TeamArtists")

  @@index([totalScore])
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique
  userId    String       @unique
  captainId String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  image     String?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  leagues   TeamLeague[]
  artists   Artist[]     @relation("TeamArtists")
}

model League {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  teams     TeamLeague[]
}

model TeamLeague {
  id       String @id @default(uuid())
  teamId   String
  leagueId String
  score    Int    @default(0)
  league   League @relation(fields: [leagueId], references: [id])
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, leagueId])
  @@index([leagueId, score])
}

model BonusMalusEvent {
  id          String          @id @default(uuid())
  artistId    String
  points      Int
  category    PointCategory   @default(BONUS)
  description String
  createdAt   DateTime        @default(now())
  createdById String?
  ruleId      String?
  artist      Artist          @relation(fields: [artistId], references: [id])
  createdBy   User?           @relation("AdminEvents", fields: [createdById], references: [id])
  rule        RuleDefinition? @relation(fields: [ruleId], references: [id])

  @@index([artistId])
}

model SystemSettings {
  id            String    @id @default(uuid())
  draftDeadline DateTime?
  updatedAt     DateTime  @updatedAt
}

model RuleDefinition {
  id          String            @id @default(uuid())
  category    PointCategory     @default(BONUS)
  title       String
  description String
  points      Int
  createdAt   DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  events      BonusMalusEvent[]
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  role      String   @default("Official Partner")
  linkUrl   String?
  createdAt DateTime @default(now())
}


enum Role {
  USER
  ADMIN
}

enum ArtistType {
  ARTISTA
  PRESENTATORE
  OSPITE
}

enum PointCategory {
  BONUS
  MALUS
  SPECIALE
}
